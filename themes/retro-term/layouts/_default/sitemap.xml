{{- printf "<?xml version=\"1.0\" encoding=\"utf-8\" standalone=\"yes\"?>" | safeHTML }}
{{- $excludedKinds := site.Params.sitemap.excludedKinds | default (slice) -}}
<urlset xmlns="http://www.sitemaps.org/schemas/sitemap/0.9" xmlns:xhtml="http://www.w3.org/1999/xhtml">
{{- range .Data.Pages -}}
  {{- $externalURL := .Param "externalUrl" -}}
  {{- $isExternal := false -}}
  {{- with $externalURL -}}
    {{- $isExternal = or (strings.HasPrefix . "http://") (strings.HasPrefix . "https://") -}}
  {{- end -}}
  {{- $xmlDisabled := and (isset .Params "xml") (not (.Param "xml")) -}}
  {{- $excluded := or .Sitemap.Disable (in $excludedKinds .Kind) $xmlDisabled (.Param "excludeFromSearch") $isExternal -}}
  {{- if not $excluded -}}
  <url>
    <loc>{{ .Permalink }}</loc>
    {{- if not .Lastmod.IsZero }}
    <lastmod>{{ .Lastmod.Format "2006-01-02T15:04:05-07:00" }}</lastmod>
    {{- end }}
    {{- with .Sitemap.ChangeFreq }}
    <changefreq>{{ . }}</changefreq>
    {{- end }}
    {{- with .Sitemap.Priority }}
    <priority>{{ . }}</priority>
    {{- end }}
    {{- if .IsTranslated }}
      {{- range .AllTranslations }}
    <xhtml:link rel="alternate" hreflang="{{ .Language.Locale | default .Language.Lang }}" href="{{ .Permalink }}" />
      {{- end }}
    {{- end }}
  </url>
  {{- end -}}
{{- end }}
</urlset>
